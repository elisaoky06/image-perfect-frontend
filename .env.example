# Copy this file to .env and fill in values. Never commit .env.

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/meddical?retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-long-random-string
PORT=5000

# Dev only (see .env.development): Vite uses VITE_API_URL so the browser talks to the API on port 5000
# directly. That avoids multipart registration failures through the Vite proxy.
